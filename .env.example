PORT=3101
HOST=127.0.0.1
NODE_ENV=development

# Optional Basic Auth for Next.js proxy calls.
BASIC_AUTH_USER=powerbi
BASIC_AUTH_PASSWORD=powerbi123

# Optional shared secret for calls from the Next.js server.
# When set, callers must send x-internal-api-key with this value.
INTERNAL_API_KEY=

# LiteLLM/OpenAI-compatible gateway.
OPENAI_BASE_URL=https://your-llm-gateway.example.com/v1
OPENAI_API_KEY=replace-me
LLM_MODEL=openai/gpt-5.4

# Fabric Power BI MCP endpoint.
PBI_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/powerbi

# Optional Microsoft OAuth compatibility routes for the browser UI.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:3000/api/powerbi-mcp/auth/callback

# Optional tuning.
MAX_AGENT_ITERATIONS=8
MCP_CACHE_TTL_MS=300000
REQUEST_TIMEOUT_MS=120000
